{
	"name": "n8n-nodes-zaple",
	"version": "0.1.4",
	"description": "n8n community node for the Zaple.ai WhatsApp Business API",
	"license": "MIT",
	"homepage": "https://github.com/MrHadik/n8n-nodes-zaple",
	"keywords": ["n8n-community-node-package", "n8n", "zaple", "whatsapp"],
	"author": { "name": "Hardik Chavda", "email": "hardik.chavda@pect.in" },
	"repository": { "type": "git", "url": "https://github.com/MrHadik/n8n-nodes-zaple.git" },
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"test": "vitest run",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": ["dist", "!dist/tsconfig.tsbuildinfo"],
	"publishConfig": { "access": "public" },
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/ZapleApi.credentials.js",
			"dist/credentials/ZapleLeadsApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Zaple/Zaple.node.js",
			"dist/nodes/ZapleTrigger/ZapleTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.23.0",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "5.9.3",
		"vitest": "^3.2.4"
	},
	"peerDependencies": { "n8n-workflow": "*" }
}
